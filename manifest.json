{
  "manifest_version": 3,
  "name": "Quick feedback",
  "version": "1.1.0",
  "description": "Generate AI based review with star rating and optional input text.",
  "permissions": ["activeTab", "scripting", "storage"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Generate a review",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  }
}
